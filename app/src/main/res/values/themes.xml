<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Geardex" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/geardex_orange</item>
        <item name="colorPrimaryVariant">@color/geardex_orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/geardex_orange_light</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/nav_background</item>
    </style>

    <style name="Theme.Geardex.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="backgroundTint">@color/nav_background</item>
    </style>

    <style name="TextAppearance.Geardex.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Geardex.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.Geardex.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">14dp</item>
    </style>

    <style name="Widget.Geardex.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/geardex_orange</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.Geardex.Button.Fuel" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_fuel</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.Geardex.Button.Service" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_service</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.Geardex.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/geardex_orange</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/surface_input</item>
    </style>

    <style name="Widget.Geardex.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/geardex_orange</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="Widget.Geardex.FAB.Glovebox" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/accent_glovebox</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="Widget.Geardex.FAB.Ekdromes" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/accent_ekdromes</item>
        <item name="tint">@color/white</item>
    </style>
</resources>
