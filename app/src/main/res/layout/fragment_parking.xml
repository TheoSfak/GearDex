<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- ── Save Parking Card ───────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Geardex.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- Title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@drawable/ic_parking"
                            app:tint="@color/accent_parking"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/parking_save_current"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Get Location button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_get_location"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/parking_get_location"
                        android:layout_marginBottom="4dp"
                        app:icon="@drawable/ic_location"
                        app:iconTint="@color/accent_parking"
                        app:backgroundTint="@color/accent_parking_bg" />

                    <TextView
                        android:id="@+id/tv_location_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent_parking"
                        android:textSize="12sp"
                        android:visibility="gone"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <!-- Address -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Geardex.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/parking_address_hint"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_parking_address"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Notes -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Geardex.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/parking_notes_hint"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_parking_notes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:minLines="2"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Meter timer button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_set_timer"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/parking_set_timer"
                        android:layout_marginBottom="4dp"
                        app:icon="@drawable/ic_timer"
                        app:iconTint="@color/accent_reminder"
                        app:backgroundTint="@color/icon_bg_amber" />

                    <TextView
                        android:id="@+id/tv_timer_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent_reminder"
                        android:textSize="12sp"
                        android:visibility="gone"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <!-- Save button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_current"
                        style="@style/Widget.Geardex.Button"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/parking_save"
                        app:backgroundTint="@color/accent_parking" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── History Header ──────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/parking_history"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <TextView
                android:id="@+id/tv_empty_parking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="@dimen/spacing_xl"
                android:text="@string/parking_empty"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_parking_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
