<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Vehicle selector -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Geardex.Dropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/logs_select_vehicle">

            <AutoCompleteTextView
                android:id="@+id/spinner_trip_vehicle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Start Odometer -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="@string/trip_start_odometer">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_start_odometer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- End Odometer -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_end_odometer"
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="@string/trip_end_odometer">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_end_odometer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Date -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="@string/trip_date">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_trip_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Purpose -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Geardex.Dropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="@string/trip_purpose">

            <AutoCompleteTextView
                android:id="@+id/spinner_purpose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Fuel Used (optional) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="@string/trip_fuel_used">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_fuel_used"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Cost (optional) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="@string/trip_cost">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_trip_cost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Notes -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:hint="@string/trip_notes">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_trip_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_trip"
            style="@style/Widget.Geardex.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/save"
            app:backgroundTint="@color/accent_trip" />

    </LinearLayout>
</ScrollView>
