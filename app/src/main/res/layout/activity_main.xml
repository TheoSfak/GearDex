<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="96dp"
        android:fitsSystemWindows="true"
        android:background="@drawable/bg_app_header"
        android:elevation="2dp"
        android:paddingStart="0dp"
        android:paddingEnd="10dp"
        app:contentInsetStart="0dp"
        app:contentInsetStartWithNavigation="56dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIconTint="@color/text_primary"
        app:title="">

        <LinearLayout
            android:id="@+id/header_brand"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="start|center_vertical"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="16dp">

            <FrameLayout
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:background="@drawable/bg_header_logo_badge"
                android:elevation="3dp">

                <ImageView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_geardex_header_logo" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_header_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="31sp"
                android:textStyle="bold" />

        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:navGraph="@navigation/nav_graph" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="14dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_bottom_dock"
        android:elevation="12dp"
        android:paddingHorizontal="8dp"
        app:itemActiveIndicatorStyle="@style/Widget.Geardex.BottomNav.ActiveIndicator"
        app:itemIconSize="22dp"
        app:itemIconTint="@color/nav_item_icon_color"
        app:itemPaddingBottom="10dp"
        app:itemPaddingTop="10dp"
        app:itemTextAppearanceActive="@style/TextAppearance.Geardex.BottomNav.Active"
        app:itemTextAppearanceInactive="@style/TextAppearance.Geardex.BottomNav.Inactive"
        app:itemTextColor="@color/nav_item_text_color"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
