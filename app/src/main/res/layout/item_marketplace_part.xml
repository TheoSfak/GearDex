<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Geardex.Card.Item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/item_margin_bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Top: Price + Condition -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_part_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_marketplace"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/accent_marketplace"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="€45.00" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_part_condition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_marketplace"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/accent_marketplace"
                android:textSize="11sp"
                tools:text="Used – Good" />

        </LinearLayout>

        <!-- Part Name -->
        <TextView
            android:id="@+id/tv_part_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            tools:text="Brake Pads - Brembo" />

        <!-- Vehicle compatibility -->
        <TextView
            android:id="@+id/tv_part_vehicle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="Honda CB500F 2020" />

        <!-- Bottom: Seller + Region -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_user"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_part_seller"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="user123" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_location"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_part_region"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="Athens" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
