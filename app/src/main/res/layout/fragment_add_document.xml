<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/glovebox_add_document"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Vehicle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vehicle_type"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinner_vehicle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/geardex_orange"
            android:layout_marginBottom="16dp" />

        <!-- Document Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/doc_type"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinner_doc_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/geardex_orange"
            android:layout_marginBottom="20dp" />

        <!-- File Picker -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_file"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/doc_pick_file"
            android:layout_marginBottom="8dp" />

        <!-- Camera capture -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_take_photo"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/doc_take_photo"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_picked_file"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"
            android:hint="No file selected" />

        <!-- Expiry Date -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_expiry"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/doc_expiry_date"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_expiry_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="32dp"
            android:hint="@string/doc_no_expiry" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_document"
            style="@style/Widget.Geardex.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/doc_save"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
