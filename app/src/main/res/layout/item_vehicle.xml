<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp"
    app:rippleColor="#1AFF6D00">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Orange left accent stripe -->
        <View
            android:id="@+id/view_accent_stripe"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@color/geardex_orange"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Main content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/view_accent_stripe"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Top row: icon + name + badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Vehicle type icon in circle -->
                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_icon_circle"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:id="@+id/iv_vehicle_type_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_car"
                        app:tint="@color/geardex_orange" />

                </FrameLayout>

                <!-- Name block -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_vehicle_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.01" />

                    <TextView
                        android:id="@+id/tv_vehicle_plate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/geardex_orange"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginTop="3dp" />

                </LinearLayout>

                <!-- Badge + chevron column -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end|center_vertical">

                    <TextView
                        android:id="@+id/tv_vehicle_type_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_hint"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="end" />

                </LinearLayout>

            </LinearLayout>

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/surface_elevated"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="10dp" />

            <!-- Bottom row: KM with icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_speed"
                    app:tint="@color/text_hint"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tv_vehicle_km"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
