<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/form_padding">

        <!-- Vehicle -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Geardex.Dropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/form_field_spacing"
            android:hint="@string/reminder_vehicle">
            <AutoCompleteTextView
                android:id="@+id/spinner_reminder_vehicle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Title -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/form_field_spacing"
            android:hint="@string/reminder_title"
            app:boxStrokeColor="@color/geardex_orange"
            app:hintTextColor="@color/text_secondary"
            app:startIconDrawable="@drawable/ic_reminder_bell"
            app:startIconTint="@color/accent_reminder">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_reminder_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Type selector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/reminder_type"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_reminder_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/form_field_spacing"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_type_km"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reminder_type_km" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_type_date"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reminder_type_date" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- KM input (shown when KM type selected) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_target_km"
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/form_field_spacing"
            android:hint="@string/reminder_target_km"
            app:boxStrokeColor="@color/geardex_orange"
            app:hintTextColor="@color/text_secondary"
            app:startIconDrawable="@drawable/ic_odometer"
            app:startIconTint="@color/accent_reminder">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_target_km"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Date picker (shown when Date type selected) -->
        <LinearLayout
            android:id="@+id/layout_target_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/form_field_spacing"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pick_date"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reminder_pick_date" />

            <TextView
                android:id="@+id/tv_selected_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/geardex_orange"
                android:textSize="14sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_reminder"
            style="@style/Widget.Geardex.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/reminder_save" />

    </LinearLayout>

</ScrollView>
