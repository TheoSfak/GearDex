<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/form_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/logs_add_service"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/header_title_size"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/form_section_spacing" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_service_km"
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/log_km"
            android:layout_marginBottom="@dimen/form_field_spacing"
            app:startIconDrawable="@drawable/ic_odometer"
            app:startIconTint="@color/accent_service">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_service_km"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_service_cost"
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/log_cost"
            android:layout_marginBottom="@dimen/form_field_spacing"
            app:startIconDrawable="@drawable/ic_money"
            app:startIconTint="@color/accent_service">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_service_cost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_mechanic"
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/log_mechanic"
            android:layout_marginBottom="@dimen/form_field_spacing"
            app:startIconDrawable="@drawable/ic_mechanic"
            app:startIconTint="@color/accent_service">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_mechanic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Common Checks -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/service_oil_change"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <CheckBox android:id="@+id/cb_oil_change" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_oil_change" android:textColor="@color/text_primary" android:buttonTint="@color/geardex_orange" android:layout_marginBottom="4dp" />
        <CheckBox android:id="@+id/cb_air_filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_air_filter" android:textColor="@color/text_primary" android:buttonTint="@color/geardex_orange" android:layout_marginBottom="4dp" />
        <CheckBox android:id="@+id/cb_brake_pads" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_brake_pads" android:textColor="@color/text_primary" android:buttonTint="@color/geardex_orange" android:layout_marginBottom="12dp" />

        <!-- Car-specific -->
        <LinearLayout
            android:id="@+id/section_car"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <CheckBox android:id="@+id/cb_timing_belt" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_timing_belt" android:textColor="@color/text_primary" android:buttonTint="@color/geardex_orange" android:layout_marginBottom="4dp" />
            <CheckBox android:id="@+id/cb_cabin_filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_cabin_filter" android:textColor="@color/text_primary" android:buttonTint="@color/geardex_orange" android:layout_marginBottom="12dp" />
        </LinearLayout>

        <!-- Motorcycle-specific -->
        <LinearLayout
            android:id="@+id/section_moto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <CheckBox android:id="@+id/cb_chain_lube" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_chain_lube" android:textColor="@color/text_primary" android:buttonTint="@color/geardex_orange" android:layout_marginBottom="4dp" />
            <CheckBox android:id="@+id/cb_valve_clearance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_valve_clearance" android:textColor="@color/text_primary" android:buttonTint="@color/geardex_orange" android:layout_marginBottom="4dp" />
            <CheckBox android:id="@+id/cb_fork_oil" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_fork_oil" android:textColor="@color/text_primary" android:buttonTint="@color/geardex_orange" android:layout_marginBottom="4dp" />
            <CheckBox android:id="@+id/cb_tire_check" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/service_tire_check" android:textColor="@color/text_primary" android:buttonTint="@color/geardex_orange" android:layout_marginBottom="12dp" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_service_notes"
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/log_notes"
            android:layout_marginBottom="@dimen/form_section_spacing"
            app:startIconDrawable="@drawable/ic_notes"
            app:startIconTint="@color/accent_service">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_service_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_service"
            style="@style/Widget.Geardex.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/log_save"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
