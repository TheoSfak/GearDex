<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Hero Header ─────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_analytics"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingTop="28dp"
            android:paddingBottom="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/analytics_title"
                    android:textColor="@android:color/white"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/analytics_subtitle"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

                <!-- Vehicle selector -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Geardex.Dropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/logs_select_vehicle"
                    android:layout_marginTop="@dimen/spacing_md">
                    <AutoCompleteTextView
                        android:id="@+id/spinner_analytics_vehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/logs_select_vehicle"
                        android:inputType="none"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- ── Hero Stat Card: Avg Economy ────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_fuel"
                        app:tint="@color/accent_fuel"
                        android:importantForAccessibility="no" />

                    <TextView
                        android:id="@+id/tv_avg_economy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/placeholder_dash"
                        android:textColor="@color/geardex_orange"
                        android:textSize="42sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/analytics_avg_economy"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:letterSpacing="0.04" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── 3-Column Stat Row ──────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/spacing_lg">

                <!-- Total Fuel Cost -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="@dimen/card_corner_radius_small"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_fuel"
                            app:tint="@color/accent_fuel"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tv_total_fuel_cost"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/placeholder_money_zero"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/analytics_total_fuel_cost"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:gravity="center" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Total Service Cost -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    app:cardCornerRadius="@dimen/card_corner_radius_small"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_wrench"
                            app:tint="@color/accent_service"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tv_total_service_cost"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/placeholder_money_zero"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/analytics_total_service_cost"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:gravity="center" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Total KM -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="@dimen/card_corner_radius_small"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_sm"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_speed"
                            app:tint="@color/text_secondary"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tv_total_km"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/placeholder_km_zero"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/analytics_total_km"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:gravity="center" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── Economy Trend Section ──────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_section_accent_bar" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="@string/analytics_economy_trend"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <com.patrykandpatrick.vico.views.cartesian.CartesianChartView
                    android:id="@+id/chart_economy"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:padding="@dimen/spacing_sm" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Monthly Spend Section ──────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/spacing_sm">

                <View
                    android:layout_width="4dp"
                    android:layout_height="22dp"
                    android:background="@drawable/bg_section_accent_bar" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="@string/analytics_monthly_spend"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <com.patrykandpatrick.vico.views.cartesian.CartesianChartView
                    android:id="@+id/chart_monthly"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:padding="@dimen/spacing_sm" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ── No Data State ──────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/tv_no_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_xxl"
                android:visibility="gone">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_fuel"
                    app:tint="#30757575"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/analytics_no_data"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/analytics_no_data_hint"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
