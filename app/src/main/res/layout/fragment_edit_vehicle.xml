<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/form_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vehicle_edit"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/header_title_size"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/form_section_spacing" />

        <!-- Vehicle Type Selector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vehicle_type"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_vehicle_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="@dimen/form_section_spacing">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_type_car"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/vehicle_type_car" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_type_motorcycle"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/vehicle_type_motorcycle" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_type_atv"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/vehicle_type_atv" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Make -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_make"
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/vehicle_make"
            android:layout_marginBottom="@dimen/form_field_spacing">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_make"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Model -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_model"
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/vehicle_model"
            android:layout_marginBottom="@dimen/form_field_spacing">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Year and Plate -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/form_field_spacing">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_year"
                style="@style/Widget.Geardex.TextInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/vehicle_year"
                android:layout_marginEnd="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_year"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_plate"
                style="@style/Widget.Geardex.TextInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/vehicle_plate"
                android:layout_marginStart="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_plate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="textCapCharacters" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Current KM -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_km"
            style="@style/Widget.Geardex.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/vehicle_km"
            android:layout_marginBottom="@dimen/form_section_spacing">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_km"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_vehicle"
            style="@style/Widget.Geardex.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/save"
            android:textSize="16sp" />

    </LinearLayout>

</ScrollView>
