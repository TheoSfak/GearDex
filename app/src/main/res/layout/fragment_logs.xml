<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Hero Header ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_logs"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:letterSpacing="-0.02"
                android:text="@string/logs_title"
                android:textColor="@color/text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Geardex.Dropdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <AutoCompleteTextView
                    android:id="@+id/spinner_vehicle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- ── Action Buttons Row ──────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_sm">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_fuel"
                style="@style/Widget.Geardex.Button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:text="@string/logs_add_fuel"
                android:textSize="13sp"
                app:backgroundTint="@color/accent_fuel"
                app:icon="@drawable/ic_gas_station"
                app:iconGravity="textStart"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_service"
                style="@style/Widget.Geardex.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:text="@string/logs_add_service"
                android:textColor="@color/accent_service"
                android:textSize="13sp"
                app:icon="@drawable/ic_tools"
                app:iconGravity="textStart"
                app:iconTint="@color/accent_service"
                app:strokeColor="@color/accent_service" />

        </LinearLayout>

        <!-- ── Tabs — pill indicator ───────────────────────────── -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_card"
            app:tabIndicator="@drawable/bg_tab_indicator"
            app:tabIndicatorColor="@color/accent_fuel"
            app:tabIndicatorHeight="4dp"
            app:tabMode="scrollable"
            app:tabRippleColor="@color/geardex_orange_soft"
            app:tabSelectedTextColor="@color/accent_fuel"
            app:tabTextColor="@color/text_secondary"
            app:tabTextAppearance="@style/Widget.Geardex.TabText">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_fuel_economy" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/logs_add_service" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_reminders" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_analytics" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_expenses" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_trips" />

        </com.google.android.material.tabs.TabLayout>

        <!-- Fuel & Service logs RecyclerView (tabs 0 & 1) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_logs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="@dimen/spacing_md" />

        <!-- Reminders panel (tab 2) -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/container_reminders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Analytics panel (tab 3) -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/container_analytics"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Expenses panel (tab 4) -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/container_expenses"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- Trips panel (tab 5) -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/container_trips"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </LinearLayout>

    <!-- FAB for adding a reminder -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_reminder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_lg"
        android:backgroundTint="@color/geardex_orange"
        android:contentDescription="@string/reminder_add_title"
        android:src="@drawable/ic_add"
        android:visibility="gone"
        app:shapeAppearance="@style/Shape.Geardex.FAB" />

    <!-- FAB for adding an expense -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_expense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_lg"
        android:backgroundTint="@color/accent_expense"
        android:contentDescription="@string/expenses_add"
        android:src="@drawable/ic_add"
        android:visibility="gone"
        app:shapeAppearance="@style/Shape.Geardex.FAB" />

    <!-- FAB for adding a trip -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_trip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_lg"
        android:backgroundTint="@color/accent_trip"
        android:contentDescription="@string/trip_add_title"
        android:src="@drawable/ic_add"
        android:visibility="gone"
        app:shapeAppearance="@style/Shape.Geardex.FAB" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
