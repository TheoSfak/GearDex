<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <!-- Main content column: hero header + recycler/empty -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Hero Header ─────────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_garage_vivid">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp"
                android:paddingTop="26dp"
                android:paddingBottom="18dp">

                <!-- Top row: Title + icon -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false" android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/garage_title"
                            android:textColor="@color/white"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:shadowColor="#40000000"
                            android:shadowDx="0"
                            android:shadowDy="1"
                            android:shadowRadius="3" />

                        <TextView
                            android:id="@+id/tv_garage_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#E6FFFFFF"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <!-- Decorative icon -->
                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_garage_header_badge">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_car"
                            app:tint="@color/white" />

                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Fleet Dashboard quick-access button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_fleet_dashboard"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/fleet_title"
            android:textSize="13sp"
            android:visibility="gone"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_dashboard"
            app:iconTint="@color/accent_fleet"
            app:backgroundTint="@color/accent_fleet_bg" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_last_parking"
            style="@style/Widget.Geardex.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            app:cardElevation="3dp"
            app:strokeColor="@color/accent_parking_bg"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="5dp"
                    android:layout_height="match_parent"
                    android:background="@color/accent_parking" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:paddingVertical="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:background="@drawable/bg_icon_circle_blue">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:importantForAccessibility="no"
                                android:src="@drawable/ic_parking"
                                app:tint="@color/accent_parking" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/parking_last_title"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_last_parking_meta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/accent_parking"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_last_parking_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tv_last_parking_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_parking_save"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="@string/parking_last_save_btn"
                            android:textSize="12sp"
                            app:backgroundTint="@color/accent_parking_bg"
                            app:icon="@drawable/ic_location"
                            app:iconSize="16dp"
                            app:iconTint="@color/accent_parking" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_parking_map"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="48dp"
                            android:layout_height="40dp"
                            android:contentDescription="@string/parking_open_map_btn"
                            android:layout_marginHorizontal="3dp"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            android:visibility="gone"
                            app:backgroundTint="@color/accent_parking_bg"
                            app:icon="@drawable/ic_location"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="18dp"
                            app:iconTint="@color/accent_parking" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_parking_share"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="48dp"
                            android:layout_height="40dp"
                            android:contentDescription="@string/parking_share_btn"
                            android:layout_marginStart="3dp"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            android:minWidth="0dp"
                            android:text=""
                            android:visibility="gone"
                            app:icon="@drawable/ic_share"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="18dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab_add_vehicle"
            style="@style/Widget.Geardex.Button"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/garage_add_vehicle"
            android:textSize="13sp"
            app:backgroundTint="@color/geardex_orange"
            app:icon="@drawable/ic_car"
            app:iconTint="@color/white" />

        <!-- ── Content Area ────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_vehicles"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="96dp" />

            <!-- Empty state — bolder, illustration-style -->
            <LinearLayout
                android:id="@+id/layout_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xxl"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="@dimen/spacing_xl"
                    android:background="@drawable/bg_icon_circle_blue">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_car"
                        app:tint="@color/accent_fuel" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/garage_empty_title"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:layout_marginBottom="@dimen/spacing_xl"
                    android:gravity="center"
                    android:text="@string/garage_empty_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_from_empty"
                    style="@style/Widget.Geardex.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/button_height"
                    android:paddingHorizontal="@dimen/spacing_xl"
                    android:text="@string/garage_add_vehicle"
                    app:icon="@drawable/ic_car"
                    app:iconTint="@color/white" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
